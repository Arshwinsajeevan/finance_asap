generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                                                                 String                         @id @default(uuid())
  name                                                               String
  email                                                              String                         @unique
  password                                                           String
  phone                                                              String?
  role                                                               String                         @default("USER")
  vertical                                                           String?
  active                                                             Boolean                        @default(true)
  createdAt                                                          DateTime                       @default(now()) @map("created_at")
  updatedAt                                                          DateTime                       @updatedAt @map("updated_at")
  departmentId                                                       String?                        @map("department_id")
  isAdmin                                                            Boolean                        @default(false) @map("is_admin")
  is_active                                                          Boolean?                       @default(true)
  department_assignees                                               department_assignees[]
  departments_departments_l1_supervisor_idTousers                    departments[]                  @relation("departments_l1_supervisor_idTousers")
  departments_departments_l2_dept_head_idTousers                     departments[]                  @relation("departments_l2_dept_head_idTousers")
  auditLogs                                                          AuditLog[]
  approvedRequests                                                   Requisition[]                  @relation("ApprovedBy")
  requisitions                                                       Requisition[]                  @relation("RaisedBy")
  salaryRecords                                                      Salary[]
  studentPayments                                                    StudentPayment[]
  transactions                                                       Transaction[]
  submittedUtilisations                                              Utilisation[]                  @relation("SubmittedBy")
  verifiedUtilisations                                               Utilisation[]                  @relation("VerifiedBy")
  fr_agreements                                                      fr_agreements[]
  fr_audit_logs                                                      fr_audit_logs[]
  fr_bulk_email_logs                                                 fr_bulk_email_logs[]
  fr_companies                                                       fr_companies[]
  fr_company_visits                                                  fr_company_visits[]
  fr_documents                                                       fr_documents[]
  fr_donor_payment_submissions                                       fr_donor_payment_submissions[]
  fr_donor_portal_access_fr_donor_portal_access_created_byTousers    fr_donor_portal_access[]       @relation("fr_donor_portal_access_created_byTousers")
  fr_donor_portal_access_fr_donor_portal_access_user_idTousers       fr_donor_portal_access[]       @relation("fr_donor_portal_access_user_idTousers")
  fr_fund_work_orders_fr_fund_work_orders_created_byTousers          fr_fund_work_orders[]          @relation("fr_fund_work_orders_created_byTousers")
  fr_fund_work_orders_fr_fund_work_orders_vertical_pm_idTousers      fr_fund_work_orders[]          @relation("fr_fund_work_orders_vertical_pm_idTousers")
  fr_fwo_progress_updates                                            fr_fwo_progress_updates[]
  fr_invoices                                                        fr_invoices[]
  fr_lead_history                                                    fr_lead_history[]
  fr_notifications                                                   fr_notifications[]
  fr_payments_fr_payments_created_byTousers                          fr_payments[]                  @relation("fr_payments_created_byTousers")
  fr_payments_fr_payments_reconciled_byTousers                       fr_payments[]                  @relation("fr_payments_reconciled_byTousers")
  fr_project_expenditures_fr_project_expenditures_approved_byTousers fr_project_expenditures[]      @relation("fr_project_expenditures_approved_byTousers")
  fr_project_expenditures_fr_project_expenditures_created_byTousers  fr_project_expenditures[]      @relation("fr_project_expenditures_created_byTousers")
  fr_proposals                                                       fr_proposals[]
  fr_refresh_tokens                                                  fr_refresh_tokens[]
  notifications                                                      notifications[]
  tbb_batches                                                        tbb_batches[]
  tick_activity_logs                                                 tick_activity_logs[]
  tick_attachments                                                   tick_attachments[]
  tick_comments                                                      tick_comments[]
  tick_department_assignees                                          tick_department_assignees[]
  tick_departments_tick_departments_l1_supervisor_idTousers          tick_departments[]             @relation("tick_departments_l1_supervisor_idTousers")
  tick_departments_tick_departments_l2_dept_head_idTousers           tick_departments[]             @relation("tick_departments_l2_dept_head_idTousers")
  tick_feedback                                                      tick_feedback[]
  tick_notifications                                                 tick_notifications[]
  tick_tickets_tick_tickets_assignee_idTousers                       tick_tickets[]                 @relation("tick_tickets_assignee_idTousers")
  tick_tickets_tick_tickets_requester_idTousers                      tick_tickets[]                 @relation("tick_tickets_requester_idTousers")
  tickets_tickets_assignee_idTousers                                 tickets[]                      @relation("tickets_assignee_idTousers")
  tickets_tickets_requester_idTousers                                tickets[]                      @relation("tickets_requester_idTousers")
  tick_departments_users_department_idTotick_departments             tick_departments?              @relation("users_department_idTotick_departments", fields: [departmentId], references: [id])

  @@map("users")
}

model Transaction {
  id              String    @id @default(uuid())
  transactionType String?   @map("transaction_type")
  source          String?
  amount          Float?
  description     String?
  reference       String?
  status          String?   @default("SUCCESS")
  userId          String?   @map("user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime? @updatedAt @map("updated_at")
  user            User?     @relation(fields: [userId], references: [id])

  @@map("fin_transactions")
}

model Requisition {
  id             String        @id @default(uuid())
  vertical       String?
  amount         Float?
  purpose        String?
  description    String?
  financialYear  String?       @map("financial_year")
  status         String?       @default("PENDING")
  rejectionNote  String?       @map("rejection_note")
  approvedAmount Float?        @map("approved_amount")
  releasedAmount Float?        @map("released_amount")
  raisedById     String?       @map("raised_by_id")
  approvedById   String?       @map("approved_by_id")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime?     @updatedAt @map("updated_at")
  approvedBy     User?         @relation("ApprovedBy", fields: [approvedById], references: [id])
  raisedBy       User?         @relation("RaisedBy", fields: [raisedById], references: [id])
  utilisations   Utilisation[]

  @@map("fin_requisitions")
}

model Budget {
  id            String    @id @default(uuid())
  vertical      String?
  financialYear String?   @map("financial_year")
  allocated     Float?    @default(0)
  used          Float?    @default(0)
  released      Float?    @default(0)
  description   String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")

  @@unique([vertical, financialYear])
  @@map("fin_budgets")
}

model Salary {
  id           String    @id @default(uuid())
  employeeType String?   @map("employee_type")
  employeeName String?   @map("employee_name")
  employeeId   String?   @map("employee_id")
  vertical     String?
  amount       Float?
  month        String?
  status       String?   @default("PENDING")
  paymentDate  DateTime? @map("payment_date")
  reference    String?
  commission   Float?
  pfAmount     Float?    @default(0) @map("pf_amount")
  tdsAmount    Float?    @default(0) @map("tds_amount")
  userId       String?   @map("user_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime? @updatedAt @map("updated_at")
  user         User?     @relation(fields: [userId], references: [id])

  @@map("fin_salaries")
}

model DonorFund {
  id         String    @id @default(uuid())
  donorName  String?   @map("donor_name")
  donorType  String?   @default("INDIVIDUAL") @map("donor_type")
  amount     Float?
  vertical   String?
  project    String?
  purpose    String?
  reference  String?
  receivedAt DateTime? @default(now()) @map("received_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")

  @@map("fin_donor_funds")
}

model BankRecord {
  id          String    @id @default(uuid())
  entryType   String?   @map("entry_type")
  bankName    String?   @map("bank_name")
  accountNo   String?   @map("account_no")
  amount      Float?
  description String?
  reference   String?
  validFrom   DateTime? @map("valid_from")
  validUntil  DateTime? @map("valid_until")
  status      String?   @default("ACTIVE")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  @@map("fin_bank_records")
}

model StudentPayment {
  id             String          @id @default(uuid())
  studentId      String?         @map("student_id")
  courseName     String?         @map("course_name")
  totalFee       Float?          @map("total_fee")
  paidAmount     Float?          @default(0) @map("paid_amount")
  installmentNo  Int?            @default(1) @map("installment_no")
  paymentType    String?         @default("FEE") @map("payment_type")
  status         String?         @default("PENDING")
  paidAt         DateTime?       @map("paid_at")
  reference      String?
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime?       @updatedAt @map("updated_at")
  refundRequests RefundRequest[]
  student        User?           @relation(fields: [studentId], references: [id])

  @@map("fin_student_payments")
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String?
  entity      String?
  entityId    String?  @map("entity_id")
  details     String?
  performedBy String?  @map("performed_by")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User?    @relation(fields: [performedBy], references: [id])

  @@map("fin_audit_logs")
}

model Utilisation {
  id            String       @id @default(uuid())
  requisitionId String?      @map("requisition_id")
  vertical      String?
  amount        Float?
  description   String?
  billNo        String?      @map("bill_no")
  proofFileUrl  String?      @map("proof_file_url")
  status        String?      @default("PENDING")
  rejectionNote String?      @map("rejection_note")
  submittedById String?      @map("submitted_by_id")
  verifiedById  String?      @map("verified_by_id")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime?    @updatedAt @map("updated_at")
  requisition   Requisition? @relation(fields: [requisitionId], references: [id])
  submittedBy   User?        @relation("SubmittedBy", fields: [submittedById], references: [id])
  verifiedBy    User?        @relation("VerifiedBy", fields: [verifiedById], references: [id])

  @@map("fin_utilisations")
}

model Invoice {
  id            String    @id @default(uuid())
  invoiceNumber String?   @unique @map("invoice_number")
  direction     String?   @default("OUTBOUND")
  vertical      String?
  clientName    String?   @map("client_name")
  panGstin      String?   @map("pan_gstin")
  baseAmount    Float?    @map("base_amount")
  gstPercent    Int?      @map("gst_percent")
  cgstAmount    Float?    @default(0) @map("cgst_amount")
  sgstAmount    Float?    @default(0) @map("sgst_amount")
  gstAmount     Float?    @map("gst_amount")
  tdsPercent    Float?    @default(0) @map("tds_percent")
  totalAmount   Float?    @map("total_amount")
  status        String?   @default("DRAFT")
  description   String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")

  @@map("fin_invoices")
}

model RefundRequest {
  id               String          @id @default(uuid())
  studentPaymentId String?         @map("student_payment_id")
  refundAmount     Float?          @map("refund_amount")
  reason           String?
  status           String?         @default("PENDING")
  rejectionNote    String?         @map("rejection_note")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime?       @updatedAt @map("updated_at")
  studentPayment   StudentPayment? @relation(fields: [studentPaymentId], references: [id])

  @@map("fin_refund_requests")
}

model Sp_Announcement {
  id        String   @id
  title     String
  date      DateTime
  type      String
  createdAt DateTime @default(now())
}

model Sp_Attendance {
  id          String      @id
  studentId   String
  date        DateTime
  status      String
  month       String
  createdAt   DateTime    @default(now())
  sp_students sp_students @relation(fields: [studentId], references: [id])
}

model Sp_PlatformUsage {
  id          String      @id
  studentId   String
  label       String
  value       Int
  total       Int
  createdAt   DateTime    @default(now())
  sp_students sp_students @relation(fields: [studentId], references: [id])
}

model Sp_StudentToTbb_Batch {
  A           String
  B           String
  sp_students sp_students @relation(fields: [A], references: [id], onDelete: Cascade)
  tbb_batches tbb_batches @relation(fields: [B], references: [id], onDelete: Cascade)

  @@id([A, B], map: "_Sp_StudentToTbb_Batch_AB_pkey")
  @@index([B], map: "_Sp_StudentToTbb_Batch_B_index")
  @@map("_Sp_StudentToTbb_Batch")
}

model categories {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  department_id  String?          @db.Uuid
  name           String           @db.VarChar(100)
  created_at     DateTime?        @default(now()) @db.Timestamptz(6)
  departments    departments?     @relation(fields: [department_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sub_categories sub_categories[]
  tickets        tickets[]
}

model department_assignees {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  department_id   String?         @db.Uuid
  user_id         String?
  sub_category_id String?         @db.Uuid
  departments     departments?    @relation(fields: [department_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sub_categories  sub_categories? @relation(fields: [sub_category_id], references: [id], onUpdate: NoAction)
  users           User?           @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([department_id, user_id, sub_category_id], map: "dept_assignees_unique")
}

model departments {
  id                                        String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                                      String                 @unique @db.VarChar(100)
  created_at                                DateTime?              @default(now()) @db.Timestamptz(6)
  l1_supervisor_id                          String?
  l2_dept_head_id                           String?
  categories                                categories[]
  department_assignees                      department_assignees[]
  users_departments_l1_supervisor_idTousers User?                  @relation("departments_l1_supervisor_idTousers", fields: [l1_supervisor_id], references: [id], onUpdate: NoAction)
  users_departments_l2_dept_head_idTousers  User?                  @relation("departments_l2_dept_head_idTousers", fields: [l2_dept_head_id], references: [id], onUpdate: NoAction)
  tickets                                   tickets[]
}

model fr_agreements {
  id                  String              @id
  fwo_id              String
  donor_id            String
  agreement_number    String              @unique
  title               String
  content             String?
  version             Int                 @default(1)
  status              Fr_AgreementStatus  @default(DRAFT)
  signed_by_donor     Boolean             @default(false)
  signed_by_asap      Boolean             @default(false)
  donor_signed_at     DateTime?
  asap_signed_at      DateTime?
  file_url            String?
  valid_from          DateTime?           @db.Date
  valid_until         DateTime?           @db.Date
  created_by          String
  created_at          DateTime            @default(now())
  updated_at          DateTime
  users               User                @relation(fields: [created_by], references: [id])
  fr_donors           fr_donors           @relation(fields: [donor_id], references: [id])
  fr_fund_work_orders fr_fund_work_orders @relation(fields: [fwo_id], references: [id])
}

model fr_audit_logs {
  id         String   @id
  user_id    String
  action     String
  table_name String
  record_id  String?
  old_value  Json?
  new_value  Json?
  ip_address String?
  created_at DateTime @default(now())
  users      User     @relation(fields: [user_id], references: [id])
}

model fr_bulk_email_logs {
  id              String   @id
  sent_by         String
  subject         String
  body            String
  company_ids     String[]
  recipient_count Int
  skipped_count   Int      @default(0)
  status          String   @default("QUEUED")
  created_at      DateTime @default(now())
  users           User     @relation(fields: [sent_by], references: [id])
}

model fr_companies {
  id                String              @id
  name              String
  category          Fr_DonorCategory
  industry          String?
  website           String?
  address           String?
  city              String?
  state             String?
  contact_person    String?
  contact_email     String?
  contact_phone     String?
  csr_budget        Decimal?            @db.Decimal(15, 2)
  normalized_name   String
  is_active         Boolean             @default(true)
  created_by        String
  created_at        DateTime            @default(now())
  updated_at        DateTime
  users             User                @relation(fields: [created_by], references: [id])
  fr_company_visits fr_company_visits[]
  fr_donors         fr_donors?
  fr_lead_history   fr_lead_history[]
  fr_proposals      fr_proposals[]

  @@unique([normalized_name, city])
}

model fr_company_visits {
  id               String                 @id
  company_id       String
  pm_user_id       String
  visit_date       DateTime               @db.Date
  visit_type       Fr_VisitType
  proposal_status  Fr_ProposalVisitStatus
  feedback         String?
  next_action      String?
  next_action_date DateTime?              @db.Date
  geo_latitude     Decimal?               @db.Decimal(9, 6)
  geo_longitude    Decimal?               @db.Decimal(9, 6)
  photos           String[]
  lead_status      Fr_LeadStatus
  created_at       DateTime               @default(now())
  updated_at       DateTime
  fr_companies     fr_companies           @relation(fields: [company_id], references: [id])
  users            User                   @relation(fields: [pm_user_id], references: [id])
}

model fr_documents {
  id                  String               @id
  entity_type         String
  entity_id           String
  proposal_id         String?
  fwo_id              String?
  file_name           String
  file_url            String
  file_size           Int?
  mime_type           String?
  uploaded_by         String
  version             Int                  @default(1)
  is_signed           Boolean              @default(false)
  signed_at           DateTime?
  created_at          DateTime             @default(now())
  fr_fund_work_orders fr_fund_work_orders? @relation(fields: [fwo_id], references: [id])
  fr_proposals        fr_proposals?        @relation(fields: [proposal_id], references: [id])
  users               User                 @relation(fields: [uploaded_by], references: [id])
}

model fr_donor_payment_submissions {
  id               String                     @id
  invoice_id       String
  donor_id         String
  amount_paid      Decimal                    @db.Decimal(15, 2)
  payment_mode     Fr_PaymentMode
  transaction_ref  String
  screenshot_url   String?
  payment_date     DateTime                   @db.Date
  status           Fr_PaymentSubmissionStatus @default(PENDING_VERIFICATION)
  verified_by      String?
  verified_at      DateTime?
  rejection_reason String?
  submitted_at     DateTime                   @default(now())
  fr_donors        fr_donors                  @relation(fields: [donor_id], references: [id])
  fr_invoices      fr_invoices                @relation(fields: [invoice_id], references: [id])
  users            User?                      @relation(fields: [verified_by], references: [id])
}

model fr_donor_portal_access {
  id                                             String    @id
  user_id                                        String
  donor_id                                       String
  last_login                                     DateTime?
  created_by                                     String?
  created_at                                     DateTime  @default(now())
  users_fr_donor_portal_access_created_byTousers User?     @relation("fr_donor_portal_access_created_byTousers", fields: [created_by], references: [id])
  fr_donors                                      fr_donors @relation(fields: [donor_id], references: [id], onDelete: Cascade)
  users_fr_donor_portal_access_user_idTousers    User      @relation("fr_donor_portal_access_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, donor_id])
}

model fr_donors {
  id                           String                         @id
  company_id                   String                         @unique
  type                         Fr_DonorCategory
  pan_number                   String?
  tan_number                   String?
  bank_account                 String?
  ifsc_code                    String?
  bank_name                    String?
  account_holder_name          String?
  total_committed              Decimal                        @default(0) @db.Decimal(15, 2)
  total_received               Decimal                        @default(0) @db.Decimal(15, 2)
  is_80g_eligible              Boolean                        @default(false)
  notes                        String?
  created_at                   DateTime                       @default(now())
  updated_at                   DateTime
  fr_agreements                fr_agreements[]
  fr_donor_payment_submissions fr_donor_payment_submissions[]
  fr_donor_portal_access       fr_donor_portal_access[]
  fr_companies                 fr_companies                   @relation(fields: [company_id], references: [id])
  fr_fund_work_orders          fr_fund_work_orders[]
  fr_invoices                  fr_invoices[]
  fr_payments                  fr_payments[]
  fr_tax_certificates          fr_tax_certificates[]
}

model fr_fund_work_orders {
  id                                              String                    @id
  fwo_number                                      String                    @unique
  proposal_id                                     String
  donor_id                                        String
  assigned_vertical                               Fr_AssignedVertical
  vertical_pm_id                                  String
  title                                           String
  total_value                                     Decimal                   @db.Decimal(15, 2)
  status                                          Fr_FWOStatus              @default(CREATED)
  start_date                                      DateTime                  @db.Date
  end_date                                        DateTime                  @db.Date
  completion_pct                                  Int                       @default(0)
  created_by                                      String
  created_at                                      DateTime                  @default(now())
  updated_at                                      DateTime
  fr_agreements                                   fr_agreements[]
  fr_documents                                    fr_documents[]
  users_fr_fund_work_orders_created_byTousers     User                      @relation("fr_fund_work_orders_created_byTousers", fields: [created_by], references: [id])
  fr_donors                                       fr_donors                 @relation(fields: [donor_id], references: [id])
  fr_proposals                                    fr_proposals              @relation(fields: [proposal_id], references: [id])
  users_fr_fund_work_orders_vertical_pm_idTousers User                      @relation("fr_fund_work_orders_vertical_pm_idTousers", fields: [vertical_pm_id], references: [id])
  fr_fwo_milestones                               fr_fwo_milestones[]
  fr_fwo_progress_updates                         fr_fwo_progress_updates[]
  fr_invoices                                     fr_invoices[]
  fr_payments                                     fr_payments[]
  fr_project_expenditures                         fr_project_expenditures[]
  fr_students                                     fr_students[]
}

model fr_fwo_milestones {
  id                  String              @id
  fwo_id              String
  title               String
  description         String?
  due_date            DateTime            @db.Date
  payment_amount      Decimal             @db.Decimal(15, 2)
  status              Fr_MilestoneStatus  @default(PENDING)
  completed_at        DateTime?
  evidence_urls       String[]
  created_at          DateTime            @default(now())
  updated_at          DateTime
  fr_fund_work_orders fr_fund_work_orders @relation(fields: [fwo_id], references: [id], onDelete: Cascade)
  fr_invoices         fr_invoices[]
}

model fr_fwo_progress_updates {
  id                  String              @id
  fwo_id              String
  updated_by          String
  completion_pct      Int
  notes               String?
  expenditure         Decimal?            @db.Decimal(15, 2)
  attachments         String[]
  created_at          DateTime            @default(now())
  fr_fund_work_orders fr_fund_work_orders @relation(fields: [fwo_id], references: [id])
  users               User                @relation(fields: [updated_by], references: [id])
}

model fr_invoices {
  id                           String                         @id
  invoice_number               String                         @unique
  fwo_id                       String
  donor_id                     String
  milestone_id                 String?
  invoice_date                 DateTime                       @db.Date
  due_date                     DateTime?                      @db.Date
  amount                       Decimal                        @db.Decimal(15, 2)
  gst_amount                   Decimal                        @default(0) @db.Decimal(15, 2)
  total_amount                 Decimal                        @db.Decimal(15, 2)
  status                       Fr_InvoiceStatus               @default(DRAFT)
  file_url                     String?
  sent_at                      DateTime?
  created_by                   String
  created_at                   DateTime                       @default(now())
  updated_at                   DateTime
