}

model tickets {
  id                                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticket_code                       String          @unique @db.VarChar(50)
  type                              String?         @db.VarChar(20)
  subject                           String          @db.VarChar(255)
  description                       String
  department_id                     String?         @db.Uuid
  category_id                       String?         @db.Uuid
  sub_category_id                   String?         @db.Uuid
  priority                          String?         @db.VarChar(20)
  status                            String?         @default("OPEN") @db.VarChar(30)
  requester_id                      String?
  assignee_id                       String?
  escalated_l1                      Boolean?        @default(false)
  escalated_l2                      Boolean?        @default(false)
  created_at                        DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at                        DateTime?       @default(now()) @db.Timestamptz(6)
  resolved_at                       DateTime?       @db.Timestamptz(6)
  closed_at                         DateTime?       @db.Timestamptz(6)
  last_requestor_action_at          DateTime?       @default(now()) @db.Timestamptz(6)
  requester_email                   String?         @db.VarChar(255)
  requester_phone                   String?         @db.VarChar(20)
  notifications                     notifications[]
  users_tickets_assignee_idTousers  User?           @relation("tickets_assignee_idTousers", fields: [assignee_id], references: [id], onUpdate: NoAction)
  categories                        categories?     @relation(fields: [category_id], references: [id], onUpdate: NoAction)
  departments                       departments?    @relation(fields: [department_id], references: [id], onUpdate: NoAction)
  sla_policies                      sla_policies?   @relation(fields: [priority], references: [priority], onDelete: NoAction, onUpdate: NoAction)
  users_tickets_requester_idTousers User?           @relation("tickets_requester_idTousers", fields: [requester_id], references: [id], onUpdate: NoAction)
  sub_categories                    sub_categories? @relation(fields: [sub_category_id], references: [id], onUpdate: NoAction)

  @@index([assignee_id], map: "idx_tickets_assignee_id")
  @@index([department_id], map: "idx_tickets_department_id")
  @@index([priority], map: "idx_tickets_priority")
  @@index([requester_id], map: "idx_tickets_requester_id")
  @@index([status], map: "idx_tickets_status")
  @@index([ticket_code], map: "idx_tickets_ticket_code")
}

